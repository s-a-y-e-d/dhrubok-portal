portal.example.com {
  encode zstd gzip

  request_body {
    max_size 25MB
  }

  reverse_proxy 127.0.0.1:3000 {
    flush_interval -1
    header_up X-Forwarded-Proto {scheme}
    header_up X-Forwarded-Host {host}
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    -Server
  }

  log {
    output file /var/log/caddy/dhrubok-access.log {
      roll_size 20MiB
      roll_keep 10
    }
    format json
  }
}
